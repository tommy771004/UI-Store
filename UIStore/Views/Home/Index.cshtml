@model IEnumerable<UIStore.Models.ProductViewModel>
<section class="hero-section fade-in delay-1" style="text-align:center; padding: 60px 20px;">
    <h1 class="hero-title" style="font-size:48px;font-weight:700;">全新 UI 模組，專為開發者設計</h1>
    <h2 class="hero-subtitle" style="font-size:24px;color:var(--text-secondary);margin-bottom:30px;">優雅、高效、好上手</h2>
</section>

<section style="max-width: 1000px; margin: 0 auto 40px auto; padding: 24px; background: var(--bg-secondary); border-radius: 18px; box-shadow: var(--shadow-soft);">
    <form method="get" asp-action="Index">
        <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 12px;">
            <div style="flex:2; min-width:160px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">分類</label>
                <select name="categoryId" style="padding:10px;margin:0;">
                    <option value="">所有分類</option>
                    @foreach(var cat in ViewBag.Categories) { <option value="@cat.Id" selected="@(ViewBag.CategoryId == cat.Id)">@cat.Name</option> }
                </select>
            </div>
            <div style="flex:4; min-width:200px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">關鍵字</label>
                <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="搜尋標題..." style="padding:10px;margin:0;" />
            </div>
            <div style="flex:2; min-width:130px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">排序方式</label>
                <select name="sortBy" style="padding:10px;margin:0;">
                    <option value="newest" selected="@(ViewBag.SortBy == "newest")">最新上架</option>
                    <option value="popular" selected="@(ViewBag.SortBy == "popular")">最熱銷</option>
                    <option value="rating" selected="@(ViewBag.SortBy == "rating")">評分最高</option>
                    <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">價格低到高</option>
                    <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">價格高到低</option>
                </select>
            </div>
            <button type="submit" class="btn-primary" style="margin:0;align-self:flex-end;">搜尋</button>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;">
            <div style="flex:2; min-width:120px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">最低價格 (NT$)</label>
                <input type="number" name="minPrice" value="@ViewBag.MinPrice" placeholder="0" min="0" style="padding:10px;margin:0;" />
            </div>
            <div style="flex:2; min-width:120px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">最高價格 (NT$)</label>
                <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" placeholder="不限" min="0" style="padding:10px;margin:0;" />
            </div>
            <div style="flex:2; min-width:120px;">
                <label style="font-size:12px;color:var(--text-secondary);display:block;margin-bottom:4px;">最低評分</label>
                <select name="minRating" style="padding:10px;margin:0;">
                    <option value="">不限</option>
                    <option value="4" selected="@(ViewBag.MinRating?.ToString() == "4")">4 星以上</option>
                    <option value="3" selected="@(ViewBag.MinRating?.ToString() == "3")">3 星以上</option>
                </select>
            </div>
            @if(!string.IsNullOrEmpty(ViewBag.Keyword?.ToString()) || ViewBag.CategoryId != null || ViewBag.MinPrice != null || ViewBag.MaxPrice != null || ViewBag.MinRating != null || (ViewBag.SortBy?.ToString() ?? "newest") != "newest") {
                <a href="/" class="btn-secondary" style="margin:0;align-self:flex-end;padding:10px 16px;font-size:13px;">清除篩選</a>
            }
        </div>
    </form>
</section>

<section class="bento-grid">
    @if(!Model.Any()) { <div class="empty-state" style="grid-column:1/-1;">找不到符合條件的模組。</div> }
    @foreach (var p in Model) {
        <div class="bento-card fade-in">
            @if(p.IsNew) { <span class="badge-new" style="position:absolute;top:20px;right:20px;background:var(--accent-orange);color:#fff;padding:4px 10px;border-radius:12px;font-size:10px;font-weight:600;z-index:3;">新款</span> }
            <div class="card-header" style="position:relative;z-index:2;margin-bottom:20px;">
                <div style="color:var(--text-secondary);font-size:12px;margin-bottom:4px;">@p.Category?.Name</div>
                <h3 class="card-subtitle" style="font-size:24px;font-weight:700;margin:0;color:var(--text-primary);">@p.Title</h3>
                <h4 style="font-size:14px;color:var(--text-secondary);margin:4px 0 0 0;">@p.Subtitle</h4>
                <div style="margin-top:6px;font-size:12px;color:#f59e0b;">
                    @if(p.AverageRating > 0) { <span>★ @p.AverageRating.ToString("0.0") (@p.ReviewCount)</span> }
                    <span style="color:var(--text-secondary);margin-left:8px;">售出 @p.SalesCount</span>
                </div>
                <div class="card-price" style="margin-top:10px;font-size:16px;color:var(--text-primary);">NT$ @p.Price.ToString("N0")</div>
            </div>
            <div style="position:absolute;bottom:30px;right:30px;z-index:10;display:flex;gap:10px;">
                <a href="/Home/Details/@p.ID" class="btn-secondary" style="padding:10px 20px;font-size:12px;">詳情</a>
                <form asp-action="AddToCart" asp-controller="Cart" method="post" style="margin:0;">
                    <input type="hidden" name="productId" value="@p.ID" />
                    <button type="submit" class="btn-primary" style="padding:10px 20px;font-size:12px;box-shadow:var(--shadow-soft);">加入購物袋</button>
                </form>
            </div>
            <div class="card-image-container"><img src="@p.ImageUrl" loading="lazy" class="card-image" onerror="this.src='https://placehold.co/600x400/e2e8f0/64748b?text=No+Image'" /></div>
        </div>
    }
</section>

@if(ViewBag.TotalPages > 1) {
    <div class="pagination">
        @if(ViewBag.CurrentPage > 1) { <a href="?keyword=@ViewBag.Keyword&categoryId=@ViewBag.CategoryId&sortBy=@ViewBag.SortBy&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&minRating=@ViewBag.MinRating&page=@(ViewBag.CurrentPage - 1)">&laquo; 上一頁</a> }
        @for(int i = 1; i <= ViewBag.TotalPages; i++) {
            if (i == ViewBag.CurrentPage) { <span class="active">@i</span> }
            else { <a href="?keyword=@ViewBag.Keyword&categoryId=@ViewBag.CategoryId&sortBy=@ViewBag.SortBy&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&minRating=@ViewBag.MinRating&page=@i">@i</a> }
        }
        @if(ViewBag.CurrentPage < ViewBag.TotalPages) { <a href="?keyword=@ViewBag.Keyword&categoryId=@ViewBag.CategoryId&sortBy=@ViewBag.SortBy&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&minRating=@ViewBag.MinRating&page=@(ViewBag.CurrentPage + 1)">下一頁 &raquo;</a> }
    </div>
}
