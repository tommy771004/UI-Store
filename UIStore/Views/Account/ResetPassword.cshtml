@model UIStore.Models.ResetPasswordViewModel
@{ ViewData["Title"] = "重設密碼"; }
<div style="max-width:480px;margin:80px auto;padding:24px;background:var(--bg-secondary);border-radius:var(--radius-md);box-shadow:var(--shadow-soft);">
    <h2 style="margin-top:0;margin-bottom:12px;">重設密碼</h2>
    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Email" readonly />
        <input asp-for="Token" type="hidden" />
        <input asp-for="Password" type="password" placeholder="新密碼" />
        <input asp-for="ConfirmPassword" type="password" placeholder="確認新密碼" />
        <button type="submit" class="btn-primary">重設密碼</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
