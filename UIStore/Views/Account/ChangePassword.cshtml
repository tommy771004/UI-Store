@{
    ViewData["Title"] = "變更密碼";
}
<div style="max-width:480px; margin:40px auto; background:var(--bg-secondary); padding:40px; border-radius:18px; box-shadow:var(--shadow-soft);">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px;">
        <a href="/Account/Profile" class="btn-secondary" style="padding:6px 14px; font-size:13px;">&larr; 返回個人資料</a>
        <h2 style="margin:0; font-size:24px;">變更密碼</h2>
    </div>

    @if (!ViewData.ModelState.IsValid) {
        <div class="validation-summary-errors" asp-validation-summary="All"></div>
    }

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <label style="display:block; margin-bottom:8px; font-weight:600;">目前密碼</label>
        <input type="password" name="currentPassword" required placeholder="輸入目前密碼" style="margin-bottom:20px;" />

        <label style="display:block; margin-bottom:8px; font-weight:600;">新密碼</label>
        <input type="password" name="newPassword" id="newPwd" required placeholder="輸入新密碼（至少 8 個字元）" style="margin-bottom:6px;" />
        <div class="pw-strength"><i id="pwBar"></i></div>
        <div class="pw-text" id="pwText"></div>

        <label style="display:block; margin-top:16px; margin-bottom:8px; font-weight:600;">確認新密碼</label>
        <input type="password" name="confirmPassword" required placeholder="再次輸入新密碼" style="margin-bottom:24px;" />

        <button type="submit" class="btn-primary" style="width:100%; padding:14px; font-size:16px;">確認變更密碼</button>
    </form>
</div>

<script>
document.getElementById('newPwd').addEventListener('input', function() {
    var v = this.value; var s = 0;
    if (v.length >= 8) s++;
    if (/[A-Z]/.test(v)) s++;
    if (/[0-9]/.test(v)) s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    var bar = document.getElementById('pwBar'); var txt = document.getElementById('pwText');
    if (v.length === 0) { bar.style.width='0'; bar.className=''; txt.textContent=''; return; }
    if (s <= 1) { bar.style.width='30%'; bar.className='pw-weak'; txt.textContent='強度：弱'; }
    else if (s === 2) { bar.style.width='60%'; bar.className='pw-medium'; txt.textContent='強度：中'; }
    else { bar.style.width='100%'; bar.className='pw-strong'; txt.textContent='強度：強'; }
});
</script>
