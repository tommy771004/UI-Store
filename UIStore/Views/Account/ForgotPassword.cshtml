@model UIStore.Models.ForgotPasswordViewModel
@{ ViewData["Title"] = "忘記密碼"; }
<div style="max-width:480px;margin:80px auto;padding:24px;background:var(--bg-secondary);border-radius:var(--radius-md);box-shadow:var(--shadow-soft);">
    <h2 style="margin-top:0;margin-bottom:12px;">忘記密碼</h2>
    <p style="color:var(--text-secondary);margin-bottom:16px;">輸入註冊時的電子郵件，我們會寄送重設密碼連結給您。</p>
    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Email" placeholder="電子郵件" />
        <button type="submit" class="btn-primary">寄送重設信</button>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
